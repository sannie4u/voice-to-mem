# Anthropic API key — used to clean up transcriptions and auto-detect category
# Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Mem API key — used to create notes in your Mem workspace
# Get from: https://mem.ai/settings/api (Settings → API)
MEM_API_KEY=your_mem_api_key_here

# Port for the backend server (default: 3001)
PORT=3001

# Frontend URL for CORS (default: Vite dev server)
FRONTEND_URL=http://localhost:5173
